<div class="min-h-screen flex flex-col items-center justify-center bg-gradient-to-br from-gray-900 via-black to-gray-800 px-4">
  <div class="max-w-md w-full bg-gray-800/80 backdrop-blur-md py-8 px-6 shadow-xl rounded-2xl border border-gray-700 text-white text-center">
    <h1 class="text-3xl font-bold mb-4">Добро пожаловать, <%= @user.email %>!</h1>
    <p class="text-gray-300 mb-6">Это ваш профиль. Здесь можно разместить настройки и информацию о пользователе.</p>

    <div class="flex flex-col space-y-3">
      <%= link_to "Редактировать профиль", edit_user_registration_path,
            class: "py-2 px-4 bg-indigo-600 hover:bg-indigo-700 rounded-md shadow text-white font-medium transition" %>

      <%= button_to "Выйти", destroy_user_session_path,
            method: :delete,
            class: "py-2 px-4 bg-red-600 hover:bg-red-700 rounded-md shadow text-white font-medium transition" %>
    </div>
  </div>
</div>
