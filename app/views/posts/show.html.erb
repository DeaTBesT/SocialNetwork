<% content_for :title, "Пост" %>

<div class="pt-28 max-w-3xl mx-auto px-4 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-900/40 mb-5 text-green-300 font-medium rounded-md inline-block" id="notice">
      <%= notice %>
    </p>
  <% end %>

  <div class="bg-gray-800/80 backdrop-blur-md p-8 shadow-xl rounded-2xl border border-gray-700">
    <h1 class="text-4xl font-bold text-white mb-6"><%= @post.title %></h1>

    <p class="text-gray-300 mb-4"><%= @post.body %></p>

    <% if @post.tags.present? %>
      <p class="text-sm text-indigo-400 mb-6">Теги: <%= @post.tags %></p>
    <% end %>

    <div class="flex flex-col sm:flex-row space-y-2 sm:space-y-0 sm:space-x-2">
      <% if user_signed_in? && @post.user == current_user %>
        <%= link_to "Редактировать пост", edit_post_path(@post),
              class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-medium transition shadow-md" %>

        <%= button_to "Удалить пост", @post, method: :delete,
              form_class: "sm:inline-block",
              class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-red-600 hover:bg-red-500 text-white font-medium cursor-pointer transition",
              data: { turbo_confirm: "Вы уверены?" } %>
      <% end %>

      <%= link_to "Назад к постам", posts_path,
            class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-700 hover:bg-gray-600 text-white font-medium transition" %>
    </div>
  </div>

  <div class="mt-8">
  <h2 class="text-2xl font-bold text-white mb-4 mt-4">Комментарии</h2>

  <% @post.comments.each do |comment| %>
    <div class="bg-gray-700/80 backdrop-blur-md p-4 rounded-xl mb-3 text-white flex justify-between items-start">
      <div>
        <p class="text-gray-300"><%= comment.body %></p>
        <p class="text-sm text-indigo-400 mt-1">
          от <%= link_to comment.user.email, profile_show_path(user_id: comment.user.id), class: "hover:underline" %>
          • <%= time_ago_in_words(comment.created_at) %> назад
        </p>
      </div>
      <% if comment.user == current_user %>
        <%= button_to "Удалить", post_comment_path(@post, comment), method: :delete,
              class: "ml-4 text-red-500 hover:text-red-400 font-medium transition", data: { turbo_confirm: "Вы уверены?" } %>
      <% end %>
    </div>
  <% end %>

  <% if user_signed_in? %>
    <%= form_with(model: [@post, Comment.new], local: true, class: "mt-4") do |f| %>
      <div>
        <%= f.label :body, "Добавить комментарий", class: "block text-sm font-medium text-gray-300" %>
        <%= f.text_area :body, rows: 3, placeholder: "Ваш комментарий...", class: "mt-1 block w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded-md text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
      <div class="mt-2">
        <%= f.submit "Отправить", class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-md shadow-md transition" %>
      </div>
    <% end %>
  <% else %>
    <p class="text-gray-400 mt-2">Чтобы комментировать, <%= link_to "войдите в систему", new_user_session_path, class: "text-indigo-400 hover:underline" %>.</p>
  <% end %>
</div>

</div>
