<% content_for :title, "Новый пост" %>

<div class="pt-28 max-w-3xl mx-auto px-4 w-full">
  <div class="bg-gray-800/80 backdrop-blur-md p-8 shadow-xl rounded-2xl border border-gray-700">

    <h1 class="text-4xl font-bold text-white mb-6">Новый пост</h1>

    <% if @post.errors.any? %>
      <div id="error_explanation" data-turbo-cache="false" class="bg-red-800/70 text-red-200 px-4 py-3 rounded-md mb-6">
        <h2 class="font-semibold mb-2">
          <%= I18n.t("errors.messages.not_saved",
                     count: @post.errors.count,
                     resource: @post.class.model_name.human.downcase) %>
        </h2>
        <ul class="list-disc list-inside">
          <% @post.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with(model: @post, local: true, class: "space-y-6") do |f| %>
      <%= f.hidden_field :user_id, value: current_user.id %>

      <div>
        <%= f.label :title, "Заголовок", class: "block text-sm font-medium text-gray-300" %>
        <%= f.text_field :title, placeholder: "Введите заголовок", required: true,
              class: "mt-1 block w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded-md text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <%= f.label :body, "Содержание", class: "block text-sm font-medium text-gray-300" %>
        <%= f.text_area :body, placeholder: "Введите текст поста", rows: 6, required: true,
              class: "mt-1 block w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded-md text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <%= f.label :tags, "Теги", class: "block text-sm font-medium text-gray-300" %>
        <%= f.text_field :tags, placeholder: "Разделяйте теги запятыми",
              class: "mt-1 block w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded-md text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <%= f.submit "Создать пост",
              class: "w-full flex justify-center py-2 px-4 rounded-md text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition shadow-md" %>
      </div>
    <% end %>

    <div class="mt-4 text-center">
      <%= link_to "Назад к постам", posts_path,
            class: "inline-block px-4 py-2 rounded-md bg-gray-700 hover:bg-gray-600 text-white font-medium transition" %>
    </div>
  </div>
</div>
