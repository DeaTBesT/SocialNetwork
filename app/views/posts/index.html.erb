<% content_for :title, "Посты" %>

<div class="pt-28 max-w-4xl mx-auto px-4 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-900/40 mb-5 text-green-300 font-medium rounded-md inline-block" id="notice">
      <%= notice %>
    </p>
  <% end %>

  <div class="flex flex-col sm:flex-row justify-between items-center mb-6">
    <h1 class="font-bold text-4xl text-white mb-4 sm:mb-0">Посты</h1>
    <%= link_to "Новый пост", new_post_path, class: "rounded-md px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium transition shadow-md" %>
  </div>

  <div id="posts" class="space-y-5">
    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <div class="bg-gray-800/80 backdrop-blur-md p-5 rounded-2xl shadow-md flex flex-col sm:flex-row justify-between items-start sm:items-center space-y-4 sm:space-y-0 sm:space-x-4 border border-gray-700">
          <!-- Содержимое поста -->
          <div class="text-white flex-1">
            <h2 class="text-xl font-semibold mb-2"><%= post.title %></h2>
            <p class="text-gray-300 mb-2"><%= truncate(post.body, length: 150) %></p>
            <% if post.tags.present? %>
              <p class="text-sm text-indigo-400">Теги: <%= post.tags %></p>
            <% end %>
          </div>

          <!-- Действия -->
          <div class="flex flex-col sm:flex-row space-y-2 sm:space-y-0 sm:space-x-2 mt-4 sm:mt-0">
            <%= link_to "Просмотр", post, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-700 hover:bg-gray-600 text-white font-medium transition" %>
            <%= link_to "Редактировать", edit_post_path(post), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-700 hover:bg-gray-600 text-white font-medium transition" %>
            <%= button_to "Удалить", post, method: :delete,
                  data: { turbo_confirm: "Вы уверены?" },
                  class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium transition cursor-pointer" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center text-gray-400 my-10">Постов пока нет.</p>
    <% end %>
  </div>
</div>
