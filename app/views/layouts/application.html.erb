<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Social Network" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
    <%= javascript_importmap_tags %>
  </head>

<body class="bg-gray-900 text-white">
  <% if user_signed_in? %>  
    <nav class="fixed top-0 left-0 right-0 bg-gray-800/90 backdrop-blur-md shadow-md z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex-shrink-0 text-xl font-bold text-indigo-400">
            X.ru
          </div>

          <div class="flex space-x-4">
            <% if user_signed_in? %>
              <%= link_to "Профиль", profile_show_path(user_id: current_user.id),
                    class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700 transition" %>

              <%= link_to "Посты", posts_path,
                    class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700 transition" %>

              <%= button_to "Выйти", destroy_user_session_path,
                    method: :delete,
                    class: "px-3 py-2 rounded-md text-sm font-medium bg-red-600 hover:bg-red-700 transition" %>
            <% else %>
              <%= link_to "Войти", new_user_session_path,
                    class: "px-3 py-2 rounded-md text-sm font-medium bg-indigo-600 hover:bg-indigo-700 transition" %>

              <%= link_to "Посты", posts_path,
                    class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700 transition" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>
  <% end %>
  <%= yield %>
</body>

</html>
