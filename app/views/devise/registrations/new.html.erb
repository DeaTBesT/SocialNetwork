<!-- app/views/devise/registrations/new.html.erb -->
<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-900 via-black to-gray-800 px-4">
  <div class="max-w-md w-full space-y-8">
    <div class="text-center">
      <!-- Лого -->
      <div class="mx-auto h-14 w-14 rounded-full flex items-center justify-center bg-gradient-to-tr from-indigo-500 to-purple-500 text-white shadow-lg">
        <span class="font-bold text-xl">X.ru</span>
      </div>
      <h2 class="mt-6 text-3xl font-extrabold text-white">Регистрация</h2>
      <p class="mt-2 text-sm text-gray-400">Создайте новый аккаунт</p>
    </div>

    <% if flash[:alert] %>
      <div class="rounded-md bg-red-900/40 p-4 text-red-300">
        <h3 class="text-sm font-medium">Ошибка</h3>
        <p class="mt-2 text-sm"><%= flash[:alert] %></p>
      </div>
    <% end %>

    <% if resource.errors.any? %>
      <div class="rounded-md bg-red-900/40 p-4 text-red-300">
        <h3 class="text-sm font-medium">Ошибка</h3>
        <ul class="mt-2 space-y-1 text-sm list-disc list-inside">
          <% resource.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="bg-gray-800/80 backdrop-blur-md py-8 px-6 shadow-xl rounded-2xl sm:px-10 border border-gray-700">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>

        <div>
          <%= f.label :email, "Электронная почта", class: "block text-sm font-medium text-gray-300" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                placeholder: "you@example.com",
                required: true,
                class: "mt-1 block w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded-md text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div>
          <%= f.label :password, "Пароль", class: "block text-sm font-medium text-gray-300" %>
          <% if @minimum_password_length %>
            <em class="text-gray-400 text-xs">(<%= @minimum_password_length %> символов минимум)</em>
          <% end %>
          <%= f.password_field :password,
                autocomplete: "new-password",
                required: true,
                placeholder: "Введите пароль",
                class: "mt-1 block w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded-md text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Подтверждение пароля", class: "block text-sm font-medium text-gray-300" %>
          <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                required: true,
                placeholder: "Повторите пароль",
                class: "mt-1 block w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded-md text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div>
          <%= f.submit "Зарегистрироваться",
                class: "w-full flex justify-center py-2 px-4 rounded-md text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition shadow-md" %>
        </div>
      <% end %>

      <div class="mt-6 text-center">
        <p class="text-sm text-gray-400">
          Уже есть аккаунт?
          <%= link_to "Войти", new_session_path(resource_name), class: "font-medium text-indigo-400 hover:text-indigo-300" %>
        </p>
      </div>

    </div>
  </div>
</div>
   